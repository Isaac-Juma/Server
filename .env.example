# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/solo-leveling
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/solo-leveling?retryWrites=true&w=majority

# ngrok Configuration (optional - for public access)
# Get your auth token from: https://dashboard.ngrok.com/get-started/your-authtoken
USE_NGROK=false
NGROK_AUTHTOKEN=your_ngrok_auth_token_here
